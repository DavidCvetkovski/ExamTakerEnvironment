# ─────────────────────────────────────────────────────────────────────────────
# OpenVision — Environment Variables Reference
# Copy this file to .env and fill in real values.
# NEVER commit a populated .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=development           # development | test | staging | production
APP_VERSION=0.1.0

# ── Security ─────────────────────────────────────────────────────────────────
# REQUIRED. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production-please

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ─────────────────────────────────────────────────────────────────
# Used by the application — points to PgBouncer in production
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=openvision
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Production: uncomment and set DATABASE_URL to point at PgBouncer
# DATABASE_URL=postgresql://openvision:changeme@pgbouncer:5432/openvision

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed frontend origins.
# Production MUST be explicit — wildcard is rejected.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ── Heartbeat Pipeline ────────────────────────────────────────────────────────
HEARTBEAT_STREAM_NAME=openvision:heartbeat:v1
HEARTBEAT_CONSUMER_GROUP=heartbeat-workers
HEARTBEAT_WORKER_BATCH_SIZE=500
HEARTBEAT_WORKER_BLOCK_MS=2500
HEARTBEAT_MAX_RETRIES=5

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true

# ── Observability ─────────────────────────────────────────────────────────────
# Optional. Leave blank to disable Sentry.
SENTRY_DSN=

# ── LTI (Epoch 12) ───────────────────────────────────────────────────────────
# Defaults to SECRET_KEY if left blank.
LTI_PRIVATE_KEY_ENCRYPTION_KEY=

# ── Safe Exam Browser & Proctoring (Epoch 11) ────────────────────────────────
# Global kill switch. When false, the SEB integrity guard passes through.
PROCTORING_ENABLED=true
# Public, browser-facing base URL SEB hashed its requests against. MUST match
# the host the .seb startURL used (scheme + host + optional port). A mismatch
# silently fails every SEB request — see docs/operations/proctoring.md.
PUBLIC_EXAM_URL_BASE=http://localhost:3000
# Enable deterministic SEB Config-Key derivation. Keep false to run BEK-only
# (admin pastes the key SEB shows) until Config-Key parity is validated against
# a real Safe Exam Browser instance.
SEB_CONFIG_KEY_ENABLED=false
# Salt for the one-way device-fingerprint hash. Defaults to SECRET_KEY if blank.
FINGERPRINT_SALT=
# Presence thresholds (seconds): < idle = green, < disconnected = yellow, else red.
PRESENCE_IDLE_SECONDS=30
PRESENCE_DISCONNECTED_SECONDS=90
