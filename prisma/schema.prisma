generator client {
  provider = "prisma-client-js"
  output   = "../frontend/node_modules/.prisma/client"
}

generator py_client {
  provider             = "prisma-client-py"
  recursive_type_depth = "5"
  interface            = "asyncio"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model alembic_version {
  version_num String @id(map: "alembic_version_pkc") @db.VarChar(32)
}

model exam_sessions {
  id                      String                   @id @default(uuid()) @db.Uuid
  test_definition_id      String                   @db.Uuid
  student_id              String                   @db.Uuid
  items                   Json
  status                  sessionstatus
  started_at              DateTime                 @db.Timestamp(6)
  submitted_at            DateTime?                @db.Timestamp(6)
  expires_at              DateTime                 @db.Timestamp(6)
  scheduled_session_id    String?                  @db.Uuid
  session_mode            examsessionmode          @default(PRACTICE)
  scheduled_exam_sessions scheduled_exam_sessions? @relation(fields: [scheduled_session_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                   users                    @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  test_definitions        test_definitions         @relation(fields: [test_definition_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  interaction_events      interaction_events[]
  question_grades         question_grades[]
  session_result          session_results?

  @@index([scheduled_session_id], map: "ix_exam_sessions_scheduled_session_id")
}

model courses {
  id                      String                    @id @default(uuid()) @db.Uuid
  code                    String                    @unique(map: "ix_courses_code") @db.VarChar
  title                   String                    @db.VarChar
  created_by              String?                   @db.Uuid
  is_active               Boolean                   @default(true)
  created_at              DateTime                  @default(now()) @db.Timestamp(6)
  updated_at              DateTime?                 @db.Timestamp(6)
  course_enrollments      course_enrollments[]
  learning_objects        learning_objects[]
  lti_context_links       lti_context_links[]
  users                   users?                    @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  scheduled_exam_sessions scheduled_exam_sessions[]
  test_definitions        test_definitions[]

  @@index([created_by], map: "ix_courses_created_by")
}

model course_enrollments {
  id          String   @id @default(uuid()) @db.Uuid
  course_id   String   @db.Uuid
  student_id  String   @db.Uuid
  is_active   Boolean  @default(true)
  enrolled_at DateTime @default(now()) @db.Timestamp(6)
  courses     courses  @relation(fields: [course_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users       users    @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([course_id, student_id], map: "uq_course_enrollment_course_student")
  @@index([course_id], map: "ix_course_enrollments_course_id")
  @@index([student_id], map: "ix_course_enrollments_student_id")
}

model scheduled_exam_sessions {
  id                        String              @id @default(uuid()) @db.Uuid
  course_id                 String              @db.Uuid
  test_definition_id        String              @db.Uuid
  created_by                String?             @db.Uuid
  starts_at                 DateTime            @db.Timestamp(6)
  ends_at                   DateTime            @db.Timestamp(6)
  status                    coursesessionstatus @default(SCHEDULED)
  duration_minutes_override Int?
  created_at                DateTime            @default(now()) @db.Timestamp(6)
  updated_at                DateTime?           @db.Timestamp(6)
  exam_sessions             exam_sessions[]
  lti_resource_links        lti_resource_links[]
  courses                   courses             @relation(fields: [course_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                     users?              @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  test_definitions          test_definitions    @relation(fields: [test_definition_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([course_id], map: "ix_scheduled_exam_sessions_course_id")
  @@index([created_by], map: "ix_scheduled_exam_sessions_created_by")
  @@index([starts_at], map: "ix_scheduled_exam_sessions_starts_at")
  @@index([test_definition_id], map: "ix_scheduled_exam_sessions_test_definition_id")
}

model item_banks {
  id               String             @id @default(uuid()) @db.Uuid
  name             String             @db.VarChar
  created_at       DateTime?          @default(now()) @db.Timestamp(6)
  created_by       String?            @db.Uuid
  users            users?             @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  learning_objects learning_objects[]
}

model item_versions {
  id                 String           @id @default(uuid()) @db.Uuid
  learning_object_id String           @db.Uuid
  version_number     Int
  status             itemstatus
  question_type      questiontype
  content            Json
  options            Json
  metadata_tags      Json?
  created_at         DateTime?        @default(now()) @db.Timestamp(6)
  created_by         String?          @db.Uuid
  users              users?           @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  learning_objects   learning_objects @relation(fields: [learning_object_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model learning_objects {
  id            String          @id @default(uuid()) @db.Uuid
  bank_id       String          @db.Uuid
  course_id     String?         @db.Uuid
  created_at    DateTime?       @default(now()) @db.Timestamp(6)
  created_by    String?         @db.Uuid
  item_versions item_versions[]
  courses       courses?        @relation(fields: [course_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  item_banks    item_banks      @relation(fields: [bank_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users         users?          @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([course_id], map: "ix_learning_objects_course_id")
}

model media_assets {
  id           String    @id @default(uuid()) @db.Uuid
  filename     String    @db.VarChar
  mime_type    String    @db.VarChar
  storage_path String    @db.VarChar
  size_bytes   Int?
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  created_by   String?   @db.Uuid
  users        users?    @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model test_definitions {
  id                      String                    @id @default(uuid()) @db.Uuid
  title                   String                    @db.VarChar
  description             String?
  created_by              String?                   @db.Uuid
  course_id               String?                   @db.Uuid
  blocks                  Json
  duration_minutes        Int
  shuffle_questions       Boolean?
  created_at              DateTime?                 @default(now()) @db.Timestamp(6)
  updated_at              DateTime?                 @db.Timestamp(6)
  scoring_config          Json?
  exam_sessions           exam_sessions[]
  lti_resource_links      lti_resource_links[]
  scheduled_exam_sessions scheduled_exam_sessions[]
  session_results         session_results[]
  courses                 courses?                  @relation(fields: [course_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                   users?                    @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([course_id], map: "ix_test_definitions_course_id")
}

model users {
  id                        String                    @id @default(uuid()) @db.Uuid
  email                     String                    @unique(map: "ix_users_email") @db.VarChar
  vunet_id                  String?                   @unique(map: "ix_users_vunet_id") @db.VarChar
  hashed_password           String                    @db.VarChar
  role                      userrole
  is_active                 Boolean                   @default(true)
  provision_time_multiplier Float                     @default(1.0)
  theme_preference          String?                   @db.VarChar
  token_version             Int                       @default(0)
  a11y_high_contrast        Boolean                   @default(false)
  a11y_dyslexia_font        Boolean                   @default(false)
  a11y_text_scale           String?                   @db.VarChar
  accommodation_enlarged_display Boolean              @default(false)
  created_at                DateTime?                 @default(now()) @db.Timestamp(6)
  accommodation_audit_log   accommodation_audit_log[]
  course_enrollments        course_enrollments[]
  courses                   courses[]
  exam_sessions             exam_sessions[]
  item_banks                item_banks[]
  item_versions             item_versions[]
  learning_objects          learning_objects[]
  lti_grade_passbacks       lti_grade_passbacks[]
  lti_launch_audits         lti_launch_audits[]
  lti_user_links            lti_user_links[]
  integration_audit_logs    integration_audit_logs[]
  media_assets              media_assets[]
  question_grades           question_grades[]
  qti_jobs                  qti_jobs[]
  scheduled_exam_sessions   scheduled_exam_sessions[]
  sis_import_jobs           sis_import_jobs[]
  published_results         session_results[]         @relation("PublishedResults")
  student_results           session_results[]         @relation("StudentResults")
  test_definitions          test_definitions[]
}

model accommodation_audit_log {
  id         String   @id @default(uuid()) @db.Uuid
  student_id String   @db.Uuid
  changed_by String   @db.Uuid
  field      String   @db.VarChar
  old_value  String   @db.VarChar
  new_value  String   @db.VarChar
  source     String   @db.VarChar
  created_at DateTime @default(now()) @db.Timestamp(6)
  student    users    @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([student_id], map: "ix_accommodation_audit_student_id")
  @@index([created_at], map: "ix_accommodation_audit_created_at")
}

model lti_platforms {
  id              String    @id @default(uuid()) @db.Uuid
  name            String    @db.VarChar
  issuer          String    @db.VarChar
  client_id       String    @db.VarChar
  auth_login_url  String    @db.VarChar
  auth_token_url  String    @db.VarChar
  auth_jwks_url   String    @db.VarChar
  deployment_ids  Json
  canvas_base_url String?   @db.VarChar
  is_active       Boolean   @default(true)
  created_at      DateTime  @default(now()) @db.Timestamp(6)
  updated_at      DateTime? @db.Timestamp(6)
  created_by      String?   @db.Uuid

  context_links   lti_context_links[]
  deployments     lti_deployments[]
  launch_audits   lti_launch_audits[]
  resource_links  lti_resource_links[]
  user_links      lti_user_links[]

  @@unique([issuer, client_id], map: "uq_lti_platform_issuer_client")
  @@index([issuer], map: "ix_lti_platforms_issuer")
  @@index([is_active], map: "ix_lti_platforms_is_active")
}

model lti_oidc_states {
  state           String    @id @db.VarChar
  nonce           String    @db.VarChar
  issuer          String    @db.VarChar
  client_id       String    @db.VarChar
  target_link_uri String    @db.VarChar
  message_hint    String?   @db.Text
  expires_at      DateTime  @db.Timestamp(6)
  consumed_at     DateTime? @db.Timestamp(6)
  created_at      DateTime  @default(now()) @db.Timestamp(6)

  @@index([expires_at], map: "ix_lti_oidc_states_expires_at")
}

model lti_deep_link_sessions {
  id              String    @id @default(uuid()) @db.Uuid
  platform_id     String    @db.Uuid
  deployment_id   String    @db.Uuid
  user_id         String    @db.Uuid
  context_link_id String?   @db.Uuid
  return_url      String    @db.VarChar
  data            String?   @db.Text
  expires_at      DateTime  @db.Timestamp(6)
  consumed_at     DateTime? @db.Timestamp(6)
  created_at      DateTime  @default(now()) @db.Timestamp(6)

  @@index([user_id], map: "ix_lti_deep_link_sessions_user_id")
  @@index([expires_at], map: "ix_lti_deep_link_sessions_expires_at")
}


model lti_deployments {
  id            String    @id @default(uuid()) @db.Uuid
  platform_id   String    @db.Uuid
  deployment_id String    @db.VarChar
  label         String?   @db.VarChar
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now()) @db.Timestamp(6)
  platform      lti_platforms @relation(fields: [platform_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  context_links  lti_context_links[]
  resource_links lti_resource_links[]

  @@unique([platform_id, deployment_id], map: "uq_lti_deployment_platform_deployment")
  @@index([deployment_id], map: "ix_lti_deployments_deployment_id")
}

model lti_tool_keys {
  id                    String    @id @default(uuid()) @db.Uuid
  kid                   String    @unique @db.VarChar
  public_jwk            Json
  encrypted_private_jwk String    @db.Text
  algorithm             String    @default("RS256") @db.VarChar
  is_active             Boolean   @default(true)
  created_at            DateTime  @default(now()) @db.Timestamp(6)
  rotated_at            DateTime? @db.Timestamp(6)

  @@index([is_active], map: "ix_lti_tool_keys_is_active")
}

model lti_user_links {
  id             String    @id @default(uuid()) @db.Uuid
  platform_id    String    @db.Uuid
  issuer         String    @db.VarChar
  subject        String    @db.VarChar
  user_id        String    @db.Uuid
  email          String?   @db.VarChar
  name           String?   @db.VarChar
  last_roles     Json?
  last_launch_at DateTime? @db.Timestamp(6)
  created_at     DateTime  @default(now()) @db.Timestamp(6)
  platform       lti_platforms @relation(fields: [platform_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user           users @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([issuer, subject], map: "uq_lti_user_links_issuer_subject")
  @@index([user_id], map: "ix_lti_user_links_user_id")
  @@index([platform_id], map: "ix_lti_user_links_platform_id")
}

model lti_context_links {
  id            String    @id @default(uuid()) @db.Uuid
  platform_id   String    @db.Uuid
  deployment_id String    @db.Uuid
  context_id    String    @db.VarChar
  context_label String?   @db.VarChar
  context_title String?   @db.VarChar
  course_id     String?   @db.Uuid
  created_at    DateTime  @default(now()) @db.Timestamp(6)
  updated_at    DateTime? @db.Timestamp(6)
  platform      lti_platforms @relation(fields: [platform_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  deployment    lti_deployments @relation(fields: [deployment_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  course        courses? @relation(fields: [course_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  resource_links lti_resource_links[]

  @@unique([platform_id, deployment_id, context_id], map: "uq_lti_context_platform_deployment_context")
  @@index([course_id], map: "ix_lti_context_links_course_id")
}

model lti_resource_links {
  id                   String    @id @default(uuid()) @db.Uuid
  platform_id          String    @db.Uuid
  deployment_id        String    @db.Uuid
  context_link_id      String?   @db.Uuid
  resource_link_id     String    @db.VarChar
  resource_title       String?   @db.VarChar
  test_definition_id   String?   @db.Uuid
  scheduled_session_id String?   @db.Uuid
  line_item_url        String?   @db.VarChar
  line_item_id         String?   @db.VarChar
  score_maximum        Float?
  created_at           DateTime  @default(now()) @db.Timestamp(6)
  updated_at           DateTime? @db.Timestamp(6)
  platform             lti_platforms @relation(fields: [platform_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  deployment           lti_deployments @relation(fields: [deployment_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  context_link         lti_context_links? @relation(fields: [context_link_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  test_definition      test_definitions? @relation(fields: [test_definition_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  scheduled_session    scheduled_exam_sessions? @relation(fields: [scheduled_session_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  grade_passbacks      lti_grade_passbacks[]

  @@unique([platform_id, deployment_id, resource_link_id], map: "uq_lti_resource_platform_deployment_resource")
  @@index([test_definition_id], map: "ix_lti_resource_links_test_definition_id")
  @@index([scheduled_session_id], map: "ix_lti_resource_links_scheduled_session_id")
}

model lti_launch_audits {
  id               String    @id @default(uuid()) @db.Uuid
  platform_id      String?   @db.Uuid
  issuer           String    @db.VarChar
  subject          String?   @db.VarChar
  user_id          String?   @db.Uuid
  deployment_id    String?   @db.VarChar
  context_id       String?   @db.VarChar
  resource_link_id String?   @db.VarChar
  message_type     String?   @db.VarChar
  status           String    @db.VarChar
  failure_reason   String?   @db.VarChar
  request_id       String?   @db.VarChar
  created_at       DateTime  @default(now()) @db.Timestamp(6)
  platform         lti_platforms? @relation(fields: [platform_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user             users? @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([issuer], map: "ix_lti_launch_audits_issuer")
  @@index([user_id], map: "ix_lti_launch_audits_user_id")
  @@index([created_at], map: "ix_lti_launch_audits_created_at")
  @@index([status], map: "ix_lti_launch_audits_status")
}

model lti_grade_passbacks {
  id                String    @id @default(uuid()) @db.Uuid
  resource_link_id  String    @db.Uuid
  session_result_id String    @db.Uuid
  student_user_id   String    @db.Uuid
  platform_user_sub String    @db.VarChar
  line_item_url     String    @db.VarChar
  score_given       Float
  score_maximum     Float
  activity_progress String    @db.VarChar
  grading_progress  String    @db.VarChar
  status            String    @db.VarChar
  attempts          Int       @default(0)
  last_error        String?   @db.Text
  last_attempt_at   DateTime? @db.Timestamp(6)
  pushed_at         DateTime? @db.Timestamp(6)
  created_at        DateTime  @default(now()) @db.Timestamp(6)
  resource_link     lti_resource_links @relation(fields: [resource_link_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  session_result    session_results @relation(fields: [session_result_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  student           users @relation(fields: [student_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([resource_link_id, session_result_id], map: "uq_lti_grade_passback_resource_result")
  @@index([status], map: "ix_lti_grade_passbacks_status")
  @@index([student_user_id], map: "ix_lti_grade_passbacks_student_user_id")
}

model sis_import_jobs {
  id           String    @id @default(uuid()) @db.Uuid
  import_type  String    @db.VarChar
  filename     String    @db.VarChar
  status       String    @db.VarChar
  total_rows   Int       @default(0)
  success_rows Int       @default(0)
  error_rows   Int       @default(0)
  created_by   String    @db.Uuid
  created_at   DateTime  @default(now()) @db.Timestamp(6)
  completed_at DateTime? @db.Timestamp(6)
  rows         sis_import_job_rows[]
  user         users @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_by], map: "ix_sis_import_jobs_created_by")
  @@index([created_at], map: "ix_sis_import_jobs_created_at")
}

model sis_import_job_rows {
  id         String   @id @default(uuid()) @db.Uuid
  job_id     String   @db.Uuid
  row_number Int
  status     String   @db.VarChar
  message    String?  @db.Text
  raw_data   Json
  created_at DateTime @default(now()) @db.Timestamp(6)
  job        sis_import_jobs @relation(fields: [job_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([job_id], map: "ix_sis_import_job_rows_job_id")
  @@index([status], map: "ix_sis_import_job_rows_status")
}

model qti_jobs {
  id            String    @id @default(uuid()) @db.Uuid
  job_type      String    @db.VarChar
  filename      String?   @db.VarChar
  status        String    @db.VarChar
  total_items   Int       @default(0)
  success_items Int       @default(0)
  error_items   Int       @default(0)
  report        Json?
  created_by    String    @db.Uuid
  created_at    DateTime  @default(now()) @db.Timestamp(6)
  completed_at  DateTime? @db.Timestamp(6)
  user          users @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_by], map: "ix_qti_jobs_created_by")
  @@index([created_at], map: "ix_qti_jobs_created_at")
}

model integration_audit_logs {
  id            String   @id @default(uuid()) @db.Uuid
  actor_user_id String?  @db.Uuid
  integration   String   @db.VarChar
  action        String   @db.VarChar
  resource_type String?  @db.VarChar
  resource_id   String?  @db.VarChar
  status        String   @db.VarChar
  metadata      Json?
  created_at    DateTime @default(now()) @db.Timestamp(6)
  actor         users? @relation(fields: [actor_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([actor_user_id], map: "ix_integration_audit_actor_user_id")
  @@index([integration], map: "ix_integration_audit_integration")
  @@index([action], map: "ix_integration_audit_action")
  @@index([created_at], map: "ix_integration_audit_created_at")
}

model interaction_events {
  id                 String               @id @default(uuid()) @db.Uuid
  session_id         String               @db.Uuid
  client_event_id    String?              @db.Uuid
  learning_object_id String?              @db.Uuid
  item_version_id    String?              @db.Uuid
  event_type         interactioneventtype
  payload            Json
  created_at         DateTime             @default(now()) @db.Timestamp(6)
  received_at        DateTime             @default(now()) @db.Timestamp(6)
  exam_sessions      exam_sessions        @relation(fields: [session_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([session_id], map: "ix_interaction_events_session_id")
  @@index([session_id, created_at], map: "ix_interaction_events_session_created_at")
  @@unique([session_id, client_event_id], map: "uq_interaction_events_session_client_event")
}

model question_grades {
  id                 String        @id @default(uuid()) @db.Uuid
  session_id         String        @db.Uuid
  learning_object_id String        @db.Uuid
  item_version_id    String        @db.Uuid
  points_awarded     Float
  points_possible    Float
  is_correct         Boolean?
  graded_by          String?       @db.Uuid
  is_auto_graded     Boolean
  feedback           String?
  rubric_data        Json?
  student_answer     Json
  correct_answer     Json?
  created_at         DateTime      @db.Timestamp(6)
  updated_at         DateTime?     @db.Timestamp(6)
  users              users?        @relation(fields: [graded_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  exam_sessions      exam_sessions @relation(fields: [session_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([session_id], map: "ix_question_grades_session_id")
}

model session_results {
  id                 String           @id @default(uuid()) @db.Uuid
  session_id         String           @unique(map: "ix_session_results_session_id") @db.Uuid
  test_definition_id String           @db.Uuid
  student_id         String           @db.Uuid
  total_points       Float
  max_points         Float
  percentage         Float
  grading_status     gradingstatus
  questions_graded   Int
  questions_total    Int
  letter_grade       String?          @db.VarChar
  passed             Boolean?
  is_published       Boolean
  details_visible    Boolean          @default(true)
  published_at       DateTime?        @db.Timestamp(6)
  published_by       String?          @db.Uuid
  created_at         DateTime         @db.Timestamp(6)
  updated_at         DateTime?        @db.Timestamp(6)
  publishers         users?           @relation("PublishedResults", fields: [published_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  exam_sessions      exam_sessions    @relation(fields: [session_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lti_grade_passbacks lti_grade_passbacks[]
  students           users            @relation("StudentResults", fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  test_definitions   test_definitions @relation(fields: [test_definition_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([student_id], map: "ix_session_results_student_id")
  @@index([test_definition_id], map: "ix_session_results_test_definition_id")
}

